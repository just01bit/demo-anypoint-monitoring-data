<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:anypoint-mq="http://www.mulesoft.org/schema/mule/anypoint-mq" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation" xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core" xmlns:file="http://www.mulesoft.org/schema/mule/file" xmlns:http="http://www.mulesoft.org/schema/mule/http" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/anypoint-mq http://www.mulesoft.org/schema/mule/anypoint-mq/current/mule-anypoint-mq.xsd http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd http://www.mulesoft.org/schema/mule/file http://www.mulesoft.org/schema/mule/file/current/mule-file.xsd http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd">
    <flow name="monitoring-data-flow" doc:id="d1a2e3f4-5678-4abc-9d01-234567890abc">
        <http:listener doc:name="HTTP Listener" doc:id="12345678-9abc-def0-1234-56789abcdef0" config-ref="HTTP_Listener_config" path="/data" allowedMethods="GET"/>
        <ee:transform doc:name="Transform Message" doc:id="abcd1234-5678-9abc-def0-1234567890ab">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
                    output application/java
                    ---
                    {
                        orgId: payload.orgId,
                        envId: payload.envId,
                        entityType: payload.entityType,
                        entityId: payload.entityId,
                        fileType: payload.fileType,
                        date: payload.date as Date {format: "yyyy-MM-dd"}
                    }]]>
                </ee:set-payload>
            </ee:message>
        </ee:transform>
        <set-variable doc:name="orgId" doc:id="lcvcsp" variableName="orgId" value="#[payload.orgId]"/>
        <set-variable doc:name="envId" doc:id="bpeezf" variableName="endId" value="#[payload.envId]"/>
        <set-variable variableName="baseURL" value="#['https://monitoring.anypoint.mulesoft.com/monitoring/archive/api/v1/organizations/' ++ (vars.orgId as  String) ++ '/environments/' ++ (vars.endId as String) ++ '/' ++ (payload.entityType as String)]" doc:name="Set Base URL"/>
        <set-variable variableName="originalPayload" value="#[payload]" doc:name="Store Original Payload"/>
        <flow-ref name="get-access-token" doc:name="Get Access Token"/>
        <http:request method="GET" doc:name="Get Resource IDs" doc:id="5678abcd-9abc-def0-1234-56789abcdef0" config-ref="HTTP_Request_configuration" url="#[vars.baseURL]" outputMimeType="application/json">
            <http:headers><![CDATA[#[output application/java
                ---
                {
                    "Authorization": "Bearer " ++ vars.accessToken
                }]]]>
            </http:headers>
        </http:request>
        <ee:transform doc:name="Filter Resources" doc:id="1234abcd-5678-9abc-def0-1234567890ab">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
                    output application/java
                    ---
                    payload.resources filter (resource) -> resource.id contains vars.originalPayload.entityId
                ]]>
                </ee:set-payload>
            </ee:message>
        </ee:transform>
        <set-variable variableName="aggregatedData" value="#[[]]" doc:name="Initialize Aggregated Data"/>
        <foreach doc:name="For Each Resource ID" doc:id="abcd5678-9abc-def0-1234-56789abcdef0" collection="#[payload]">
            <set-variable variableName="currentResourceId" value="#[payload.id]" doc:name="Store Current Resource ID"/>
            <http:request method="GET" doc:name="Get File Metadata" config-ref="HTTP_Request_configuration" url="#[vars.baseURL ++ '/' ++ payload.id ++ '/' ++ vars.originalPayload.fileType ++ '/' ++ vars.originalPayload.date.year ++ '/' ++ (vars.originalPayload.date.month as String {format: '00'}) ++ '/' ++ (vars.originalPayload.date.day as String {format: '00'})]" outputMimeType="application/json">
                <http:headers><![CDATA[#[output application/java
                    ---
                    {
                        "Authorization": "Bearer " ++ vars.accessToken
                    }]]]>
                </http:headers>
            </http:request>
            <ee:transform doc:name="Aggregate Data" doc:id="5678abcd-1234-9abc-def0-1234567890ab">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
                        output application/json
                        ---
                        payload.resources map (resource) -> {
                            fileName: resource.id,
                            time: resource.time,
                            resourceId: vars.currentResourceId
                        }
                    ]]></ee:set-payload>
                </ee:message>
            </ee:transform>
            <set-variable variableName="aggregatedData" value="#[vars.aggregatedData ++ payload]" doc:name="Accumulate Data"/>
        </foreach>
        <ee:transform doc:name="Set Aggregated Payload" doc:id="set-aggregated-payload">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
                    output application/json
                    ---
                    vars.aggregatedData
                ]]></ee:set-payload>
            </ee:message>
        </ee:transform>
        <ee:transform doc:name="Sort Data" doc:id="9abc1234-5678-def0-1234-56789abcdef0">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
                    output application/json
                    ---
                    {
                        data: payload orderBy ((item) -> item.time)
                    }]]>
                </ee:set-payload>
            </ee:message>
        </ee:transform>
        <foreach doc:name="Push to Anypoint MQ" doc:id="1234abcd-5678-9abc-def0-1234567890ab" collection="#[payload.data]">
            <set-variable doc:name="fileName" doc:id="ryoxkx" variableName="fileName" value="#[payload.fileName]"/>
            
            <ee:transform doc:name="Prepare MQ Message" doc:id="prepare-mq-message">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
                        output application/json
                        ---
                        {
                            fileName: payload.fileName,
                            time: payload.time,
                            resourceId: payload.resourceId,
                            downloadUrl: vars.baseURL ++ '/' ++ payload.resourceId ++ '/' ++ vars.originalPayload.fileType ++ '/' ++ vars.originalPayload.date.year ++ '/' ++ (vars.originalPayload.date.month as String {format: '00'}) ++ '/' ++ (vars.originalPayload.date.day as String {format: '00'}) ++ '/' ++ payload.fileName,
                            accessToken: vars.accessToken
                        }]]>
                    </ee:set-payload>
                </ee:message>
            </ee:transform>
            <anypoint-mq:publish doc:name="Publish to MQ" config-ref="Anypoint_MQ_Config" destination="demo-anypoint-monitoring-data">
                <anypoint-mq:body><![CDATA[#[payload]]]></anypoint-mq:body>
            </anypoint-mq:publish>
        </foreach>
    </flow>
    
