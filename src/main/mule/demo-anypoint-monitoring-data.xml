    <sub-flow name="get-access-token" doc:id="abcd1234-5678-9abc-def0-1234567890ab">
        <http:request method="POST" doc:name="Request Token" config-ref="HTTP_Request_configuration" url="https://anypoint.mulesoft.com/accounts/api/v2/oauth2/token" outputMimeType="application/json">
            <http:body><![CDATA[#[%dw 2.0
                output application/json
                ---
                {
                    client_id: p('connectedAppClientId'),
                    client_secret: p('connectedAppClientSecret'),
                    grant_type: "client_credentials"
                }]]]></http:body>
        </http:request>
        <set-variable variableName="accessToken" value="#[payload.access_token]" doc:name="Set Access Token"/>
    </sub-flow>
</mule>